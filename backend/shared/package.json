{
  "name": "@properpos/backend-shared",
  "version": "1.0.0",
  "description": "Shared utilities and middleware for ProperPOS Backend Services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "migration:create": "migrate create --template-file ./migrations/template.js --migrations-dir=./migrations",
    "migration:run": "migrate up --migrations-dir=./migrations",
    "migration:rollback": "migrate down --migrations-dir=./migrations",
    "seed:run": "node dist/seeds/index.js"
  },
  "dependencies": {
    "@properpos/shared": "*",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "express-async-errors": "^3.1.1",
    "morgan": "^1.10.0",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "mongoose": "^7.5.0",
    "redis": "^4.6.7",
    "ioredis": "^5.3.2",
    "bullmq": "^4.10.0",
    "nodemailer": "^6.9.4",
    "twilio": "^4.15.0",
    "stripe": "^13.4.0",
    "axios": "^1.5.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.5",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "uuid": "^9.0.0",
    "crypto": "^1.0.1",
    "zod": "^3.22.0",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/compression": "^1.7.2",
    "@types/morgan": "^1.9.4",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/bcryptjs": "^2.4.3",
    "@types/nodemailer": "^6.4.9",
    "@types/multer": "^1.4.7",
    "@types/uuid": "^9.0.3",
    "@types/lodash": "^4.14.196",
    "@types/node": "^20.0.0",
    "jest": "^29.6.0",
    "@types/jest": "^29.5.4",
    "ts-jest": "^29.1.1",
    "typescript": "^5.1.6",
    "migrate": "^2.0.1"
  },
  "files": [
    "dist/**/*"
  ]
}