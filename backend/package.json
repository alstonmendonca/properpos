{
  "name": "@properpos/backend",
  "version": "1.0.0",
  "description": "ProperPOS SaaS Backend - Microservices API",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:tenant\" \"npm run dev:pos\"",
    "dev:gateway": "cd services/gateway && npm run dev",
    "dev:auth": "cd services/auth && npm run dev",
    "dev:tenant": "cd services/tenant && npm run dev",
    "dev:pos": "cd services/pos && npm run dev",
    "dev:inventory": "cd services/inventory && npm run dev",
    "dev:analytics": "cd services/analytics && npm run dev",
    "dev:billing": "cd services/billing && npm run dev",
    "dev:notification": "cd services/notification && npm run dev",
    "dev:audit": "cd services/audit && npm run dev",

    "build": "npm run build:shared && npm run build:services",
    "build:shared": "cd shared && npm run build",
    "build:services": "concurrently \"npm run build:gateway\" \"npm run build:auth\" \"npm run build:tenant\" \"npm run build:pos\" \"npm run build:inventory\" \"npm run build:analytics\" \"npm run build:billing\" \"npm run build:notification\" \"npm run build:audit\"",
    "build:gateway": "cd services/gateway && npm run build",
    "build:auth": "cd services/auth && npm run build",
    "build:tenant": "cd services/tenant && npm run build",
    "build:pos": "cd services/pos && npm run build",
    "build:inventory": "cd services/inventory && npm run build",
    "build:analytics": "cd services/analytics && npm run build",
    "build:billing": "cd services/billing && npm run build",
    "build:notification": "cd services/notification && npm run build",
    "build:audit": "cd services/audit && npm run build",

    "start": "pm2 start ecosystem.config.js",
    "start:gateway": "cd services/gateway && npm start",
    "start:auth": "cd services/auth && npm start",
    "start:tenant": "cd services/tenant && npm start",
    "start:pos": "cd services/pos && npm start",
    "start:inventory": "cd services/inventory && npm start",
    "start:analytics": "cd services/analytics && npm start",
    "start:billing": "cd services/billing && npm start",
    "start:notification": "cd services/notification && npm start",
    "start:audit": "cd services/audit && npm start",

    "test": "jest --projects services/*/jest.config.js",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:coverage": "jest --coverage",

    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "type-check": "tsc --noEmit --project tsconfig.json",

    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",

    "migration:create": "cd shared && npm run migration:create",
    "migration:run": "cd shared && npm run migration:run",
    "migration:rollback": "cd shared && npm run migration:rollback",
    "seed:run": "cd shared && npm run seed:run",

    "docs:generate": "swagger-jsdoc -d docs/swagger.config.js services/*/src/routes/*.ts -o docs/api.json && swagger-ui-serve docs/api.json",
    "docs:serve": "swagger-ui-serve docs/api.json",

    "clean": "rimraf dist services/*/dist",
    "clean:deps": "rimraf node_modules services/*/node_modules",
    "postinstall": "npm run install:services",
    "install:services": "concurrently \"cd shared && npm install\" \"cd services/gateway && npm install\" \"cd services/auth && npm install\" \"cd services/tenant && npm install\" \"cd services/pos && npm install\" \"cd services/inventory && npm install\" \"cd services/analytics && npm install\" \"cd services/billing && npm install\" \"cd services/notification && npm install\" \"cd services/audit && npm install\""
  },
  "workspaces": [
    "shared",
    "services/*"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.6.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.6.3",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "author": {
    "name": "ProperPOS Team",
    "email": "team@properpos.com"
  },
  "license": "PROPRIETARY",
  "repository": {
    "type": "git",
    "url": "https://github.com/properpos/properpos-saas"
  },
  "keywords": [
    "pos",
    "point-of-sale",
    "saas",
    "restaurant",
    "retail",
    "microservices",
    "api"
  ]
}