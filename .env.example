# ProperPOS SaaS Environment Configuration
# Copy this file to .env and update ALL placeholder values before running
#
# IMPORTANT: Never commit .env files with real credentials to version control.
# Use a secrets manager (AWS Secrets Manager, HashiCorp Vault) for production.

# ===================
# General
# ===================
NODE_ENV=development

# ===================
# Database
# ===================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_mongo_password
MONGODB_URI=mongodb://admin:CHANGE_ME_mongo_password@localhost:27017/properpos_platform?authSource=admin

# Pool settings (adjust per environment)
MONGODB_PLATFORM_POOL_SIZE=10
MONGODB_TENANT_POOL_SIZE=5
MONGODB_MIN_POOL_SIZE=1

# ===================
# Redis
# ===================
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6379
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_MS=1000

# ===================
# JWT Authentication
# ===================
# CRITICAL: Generate strong random secrets (min 32 chars)
# Example: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===================
# Security
# ===================
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=1800000
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
CORS_MAX_AGE=0
CSRF_ENABLED=false

# ===================
# Rate Limiting
# ===================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=100
SENSITIVE_RATE_LIMIT_WINDOW_MS=3600000
SENSITIVE_RATE_LIMIT_MAX_REQUESTS=50

# ===================
# Cache TTLs (seconds)
# ===================
CACHE_DEFAULT_TTL=60
CACHE_SESSION_TTL=3600
CACHE_PERMISSION_TTL=60
CACHE_ANALYTICS_TTL=60
CACHE_PRODUCT_TTL=60

# ===================
# Logging
# ===================
LOG_LEVEL=debug
LOG_INCLUDE_STACK=true
LOG_PRETTY_PRINT=true
ENABLE_API_LOGGING=true
ENABLE_QUERY_LOGGING=false

# ===================
# API Timeouts (milliseconds)
# ===================
API_DEFAULT_TIMEOUT_MS=30000
API_ANALYTICS_TIMEOUT_MS=60000
API_UPLOAD_TIMEOUT_MS=120000
API_BULK_TIMEOUT_MS=90000
API_MAX_REQUEST_SIZE_MB=10

# ===================
# Stripe (Billing)
# ===================
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ===================
# Email (SMTP)
# ===================
# Development: Use Mailtrap (https://mailtrap.io)
# Production: Use SendGrid, SES, etc.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=CHANGE_ME_smtp_user
SMTP_PASS=CHANGE_ME_smtp_password
SMTP_FROM=noreply@properpos.com

# ===================
# Twilio (SMS)
# ===================
TWILIO_SID=CHANGE_ME_twilio_sid
TWILIO_AUTH_TOKEN=CHANGE_ME_twilio_auth_token
TWILIO_PHONE=+1234567890

# ===================
# Firebase (Push Notifications)
# ===================
FIREBASE_PROJECT_ID=CHANGE_ME_project_id
FIREBASE_CLIENT_EMAIL=CHANGE_ME_client_email
FIREBASE_PRIVATE_KEY=CHANGE_ME_private_key

# ===================
# Web Push (VAPID)
# ===================
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME_vapid_public_key
VAPID_PRIVATE_KEY=CHANGE_ME_vapid_private_key
VAPID_EMAIL=mailto:admin@properpos.com

# ===================
# Feature Flags
# ===================
FEATURE_MFA=true
FEATURE_WEB_PUSH=false
FEATURE_EMAIL=false
FEATURE_SMS=false
FEATURE_ANALYTICS=true
FEATURE_AUTO_BACKUP=false

# ===================
# Service URLs (internal)
# ===================
FRONTEND_URL=http://localhost:8080
NOTIFICATION_SERVICE_URL=http://localhost:3008

# ===================
# Receipt Security
# ===================
# Used to sign receipt URLs - generate a strong random string
RECEIPT_URL_SECRET=CHANGE_ME_generate_random_secret

# ===================
# Frontend
# ===================
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_NAME=ProperPOS
NEXT_PUBLIC_APP_URL=http://localhost:8080

# ===================
# Monitoring (Optional)
# ===================
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# ===================
# Service Ports (reference)
# ===================
# Gateway:      3000
# Auth:         3001
# Tenant:       3002
# POS:          3003
# Inventory:    3004
# Analytics:    3005
# Billing:      3006
# Notification: 3008
# Audit:        3009
# Frontend:     8080
